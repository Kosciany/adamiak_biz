{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Zrzuty ekranu (responsywność)",
      "detail": "Generuje zrzuty mobile/tablet/desktop do screenshots/ i otwiera katalog",
      "type": "shell",
      "command": "bash screenshots.sh && xdg-open screenshots 2>/dev/null",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "prod-local-compare (pixel diff)",
      "detail": "Porównuje www.adamiak.biz z lokalnym index.html i zapisuje *_diff.png",
      "type": "shell",
      "command": "bash compare-prod-local.sh && xdg-open screenshots/compare 2>/dev/null",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "group": "build"
    }
  ]
}
