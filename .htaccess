# === adamiak.biz — konfiguracja serwera (Apache / OVH) ===

AddDefaultCharset UTF-8

# --- Wymuszenie HTTPS + kanoniczny host www ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Każde żądanie po http LUB bez "www" -> https://www.adamiak.biz
  # (jeśli subdomena www nie jest skonfigurowana w OVH, usuń drugi warunek RewriteCond)
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.adamiak.biz%{REQUEST_URI} [L,R=301]
</IfModule>

# --- Kompresja gzip ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml \
    application/javascript application/x-javascript application/json \
    application/ld+json application/xml application/rss+xml \
    image/svg+xml application/manifest+json
</IfModule>

# --- Kompresja brotli (jeśli serwer ma mod_brotli) ---
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml \
    application/javascript application/json application/ld+json \
    application/xml image/svg+xml application/manifest+json
</IfModule>

# --- Cache przeglądarki ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"
  ExpiresByType text/html                 "access plus 0 seconds"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  # HTML zawsze świeży
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Statyczne zasoby — długo i niezmiennie
  <FilesMatch "\.(css|js|webp|jpe?g|png|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Nagłówki bezpieczeństwa
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # HSTS — odkomentuj, gdy masz pewność, że cała domena działa po HTTPS:
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# --- Typy MIME (na wszelki wypadek) ---
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
</IfModule>

# Bez listowania katalogów
Options -Indexes
